# 환경변수 (시크릿)
.env
.env.local
.env.*.local

# 자관 데이터 보안 (PIPA·tenant_isolation·옵션 2 명령)
# 측정 결과 JSON만 commit·원본 .mrc·매핑 테이블·합성 ID = git X
docs/eval/raw/
docs/eval/private/
docs/eval/results/*/raw_records.json
docs/eval/results/*/anonymization_mapping.json
*.mrc
!tests/samples/golden/*.mrc

# Streamlit secrets (ADR 0011·DECISIONS 6dim+7 — Part G Step 2·4)
.streamlit/auth_config.yaml
.streamlit/secrets.toml
.streamlit/secrets.toml.bak

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml

# 가상환경
.venv/
venv/
env/
ENV/

# 빌드
build/
dist/
*.whl

# 출력 .mrc 파일 (생성물, 커밋 금지). src/kormarc_auto/output/ 소스 디렉토리는 제외 안 됨.
/output/
*.mrc
!tests/samples/golden/*.mrc

