# ─────────────────────────────────────────────────
# kormarc-auto 환경변수 — .env로 복사 후 채우세요
# .env는 절대 git에 커밋 금지 (.gitignore에 포함됨)
# ─────────────────────────────────────────────────

# 국립중앙도서관 ISBN 서지정보 API
# 발급: https://www.nl.go.kr/seoji/contents/S80100000000.do
# 회원가입 → 인증키 신청 → 담당자 승인(1~3 영업일)
NL_CERT_KEY=여기에_발급키

# 알라딘 OPEN API (TTBKey)
# 발급: https://www.aladin.co.kr/ttb/wblog_manage.aspx
# 블로그 등록 후 1~2일 소요
# 출처 표시 의무: "도서 DB 제공 : 알라딘 인터넷서점(www.aladin.co.kr)"
ALADIN_TTB_KEY=여기에_TTBKey

# 카카오 도서 검색 API (보조)
# 발급: https://developers.kakao.com → 앱 생성 → REST API 키
# 일일 30,000회 무료
KAKAO_API_KEY=여기에_REST_API_키

# Anthropic Claude API (Vision + KDC 분류)
# 발급: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-여기에_키

# 도서관 정보나루 (선택, 키워드/대출통계용)
# 발급: https://www.data4library.kr
DATA4LIBRARY_AUTH_KEY=

# 출력 폴더 (KOLAS 자동 반입 폴더로 지정 가능)
# 예: D:\KOLAS\Import 또는 ./output
KORMARC_OUTPUT_DIR=./output

# Claude 모델 선택
CLAUDE_VISION_MODEL=claude-sonnet-4-6
CLAUDE_TEXT_MODEL=claude-sonnet-4-6
CLAUDE_LIGHT_MODEL=claude-haiku-4-5-20251001

# ─── REST 서버 인증 (kormarc-server 사용 시) ─────────────
# 화이트리스트 모드: 쉼표로 키 나열 (지정 안 하면 모든 8자+ 키 통과 — 개발용)
KORMARC_USER_KEYS=
# 관리자 키 (모든 사용량 무제한)
KORMARC_ADMIN_KEYS=

# 서버 호스트·포트
KORMARC_HOST=127.0.0.1
KORMARC_PORT=8000
KORMARC_UI_PORT=8501

# CORS 허용 도메인 (쉼표 구분, 기본 *)
KORMARC_CORS_ORIGINS=*

# DLS 출력 폴더 (학교도서관용 별도)
KORMARC_DLS_OUTPUT_DIR=./output/dls

# 캐시 폴더 (anthropic 응답 + 외부 API 응답)
KORMARC_CACHE_DIR=.cache/kormarc-auto

# 사용량 DB·로그 (FastAPI 서버용)
KORMARC_USAGE_DB=logs/usage.json
KORMARC_USAGE_LOG=logs/usage.jsonl

# ─── 결제 PG (ADR 0007 트리거 후 활성화) ──────────────────
# 어댑터 선택: local (기본·수동 입금) | portone (정식·정기결제 자동) | stripe (미국 §33)
# 사업자 등록 + 통신판매 신고 + 포트원 가맹 완료 후 portone 전환.
KORMARC_PG_PROVIDER=local

# 포트원 (https://portone.io) — 정식 결제 활성 시
KORMARC_PORTONE_API_KEY=
KORMARC_PORTONE_API_SECRET=
KORMARC_PORTONE_CHANNEL_KEY=

# 사업자 정보 (세금계산서 발행자) — 학교·공공 결제팀 필수
KORMARC_BIZ_NO=

# 포트원 webhook secret (결제 완료 알림 검증)
KORMARC_PORTONE_WEBHOOK_SECRET=

# Stripe (ADR 0009 §33 미국 활성화 시 — 현재 inactive)
KORMARC_STRIPE_API_KEY=
KORMARC_EAST_ASIAN_ACTIVATED=0
